# 加入现有组网配置示例
#
# 所有配置都使用 .env 方式，不区分平台。
# 多值变量统一使用英文逗号分隔。
#
# 推荐设置：
# - 普通客户端建议 PRIVATE_MODE=true
# - 如果希望客户端地址固定，建议 USE_DHCP=false 并明确填写 NODE_IPV4
# - 建议同时配置一个 TCP 和一个 UDP 上游入口
# - 普通客户端一般不需要 LISTENER_URLS 和 MAPPED_LISTENERS

# 组网名称。必须和入口节点一致。
# 推荐设置：与入口节点完全一致，不要有大小写差异。
NETWORK_NAME=example-easytier

# 组网密钥。必须和入口节点一致。
# 推荐设置：与入口节点完全一致。
NETWORK_SECRET=please-change-me

# 当前客户端在组网内显示的名称。
# 推荐设置：使用能区分机器用途的名字，例如 macbook-dev、office-pc、ci-runner。
HOSTNAME=client-node

# 当前 easytier 实例名。
# 同一台机器如果运行多个实例，这个值必须唯一。
# 推荐设置：单实例场景可直接用 client。
INSTANCE_NAME=client

# 是否启用私有模式。
# 建议保持 true。
# 推荐设置：true
PRIVATE_MODE=true

# 是否使用 DHCP 自动分配虚拟 IP。
# 如果想给客户端固定 IP，可设为 false 并填写 NODE_IPV4。
# 推荐设置：如果节点数量不多且希望稳定访问，建议 false。
USE_DHCP=false

# 当 USE_DHCP=false 时使用的虚拟 IP。
# 推荐设置：为每台客户端分配唯一地址，例如 10.144.144.2、10.144.144.3。
NODE_IPV4=10.144.144.2

# 是否关闭 TUN。
# 如果不需要虚拟网卡，可改成 true。
# 推荐设置：false
NO_TUN=false

# 上游入口节点地址列表，多个值用英文逗号分隔。
# 客户端一般至少配置一个 TCP 或 UDP 入口。
# 推荐设置：同时配置 TCP 和 UDP，优先指向公网入口节点。
PEER_URLS=tcp://122.123.124.125:11010,udp://122.123.124.125:11010

# 可选：客户端监听地址。
# 普通加入组网场景一般留空。
# 推荐设置：留空
LISTENER_URLS=

# 可选：客户端对外公布的监听地址。
# 推荐设置：留空
MAPPED_LISTENERS=

# 可选：客户端要暴露给组网内其它节点访问的本地网段。
# 推荐设置：默认留空，只有需要共享本地局域网时再填写。
PROXY_NETWORKS=

# easytier 的本地 RPC 管理地址。
# 推荐设置：127.0.0.1:15888
RPC_PORTAL=127.0.0.1:15888

# 可选：手动指定 machine-id。
# 一般留空，脚本会自动使用系统标识。
# 推荐设置：留空
MACHINE_ID=

# 运行状态目录。
# 推荐设置：保持默认
STATE_DIR=${ROOT_DIR}/.state/join

# 日志输出目录。
# 推荐设置：保持默认
LOG_DIR=${ROOT_DIR}/logs/join

# 控制台日志级别。
# 推荐设置：info
CONSOLE_LOG_LEVEL=info

# 文件日志级别。
# 推荐设置：info
FILE_LOG_LEVEL=info

# 可选：允许的 TCP 端口白名单。
# 推荐设置：默认留空
TCP_WHITELIST=

# 可选：允许的 UDP 端口白名单。
# 推荐设置：默认留空
UDP_WHITELIST=

# 可选：透传给 easytier-core 的额外参数。
# 多个值用英文逗号分隔；带值参数写成 key=value。
# 例如：--accept-dns=true,--mtu=1360
# 推荐设置：默认留空，只有明确需要高级参数时再填写
EXTRA_ARGS=


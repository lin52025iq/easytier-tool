# EasyTier 可执行文件名映射示例
#
# 使用方式：
# 1. 执行 ./easytierctl init executables 生成根目录 .env.executables
# 2. 把可执行文件复制到项目根目录的 bin/
# 3. 如果文件名和下面默认值不同，就改成实际文件名
#
# 变量含义：
# - EASYTIER_CORE_FILENAME：实际启动的 easytier-core 文件名
# - EASYTIER_CLI_FILENAME：实际调用的 easytier-cli 文件名
# - EASYTIER_WEB_FILENAME：实际调用的 easytier-web 文件名
# - EASYTIER_WEB_EMBED_FILENAME：实际调用的 easytier-web-embed 文件名
#
# 推荐设置：
# - 推荐直接保持 EasyTier 官方默认文件名，减少额外配置
# - 只有在你复制到 bin/ 的文件名带平台后缀、版本后缀时再修改
# - 这里只定义“文件名”，不定义目录；目录固定为项目根目录 bin/

# easytier-core 的实际文件名。
# 如果你放到 bin/ 下的文件名就是 easytier-core，就不用改。
EASYTIER_CORE_FILENAME=easytier-core

# easytier-cli 的实际文件名。
EASYTIER_CLI_FILENAME=easytier-cli

# easytier-web 的实际文件名。
EASYTIER_WEB_FILENAME=easytier-web

# easytier-web-embed 的实际文件名。
EASYTIER_WEB_EMBED_FILENAME=easytier-web-embed

# 创建组网入口节点配置示例
#
# 所有配置都使用 .env 方式，不区分平台。
# 多值变量统一使用英文逗号分隔。
#
# 推荐设置：
# - 作为公网入口节点时，建议固定虚拟 IP 为网段第一个地址，例如 10.144.144.1
# - 建议同时开放一个 TCP 和一个 UDP 监听入口
# - 建议 PRIVATE_MODE=true
# - 建议 USE_DHCP=false
# - 如果这台机器是公网服务器，MAPPED_LISTENERS 建议填写公网 IP + 端口

# 组网名称。所有节点必须保持一致。
# 推荐设置：使用一个清晰、稳定的名字，例如 company-prod-et 或 home-lab-et。
NETWORK_NAME=example-easytier

# 组网密钥。所有节点必须保持一致，建议使用复杂一些的值。
# 推荐设置：使用足够长的随机字符串，不要使用弱口令。
NETWORK_SECRET=please-change-me

# 当前节点在组网内显示的名称。
# 推荐设置：如果是入口机，可使用 relay、gateway、vps-relay 之类便于识别的名称。
HOSTNAME=relay-node

# 当前 easytier 实例名。
# 同一台机器如果运行多个实例，这个值必须唯一。
# 推荐设置：单实例场景可直接用 relay。
INSTANCE_NAME=relay

# 是否启用私有模式。
# 建议保持 true，避免非预期节点加入。
# 推荐设置：true
PRIVATE_MODE=true

# 是否使用 DHCP 自动分配虚拟 IP。
# 入口节点通常建议固定 IP，所以这里一般设为 false。
# 推荐设置：false
USE_DHCP=false

# 当 USE_DHCP=false 时使用的虚拟 IP。
# 常见入口节点写法是网段里的第一个地址，例如 10.144.144.1。
# 推荐设置：10.144.144.1
NODE_IPV4=10.144.144.1

# 是否关闭 TUN。
# 如果只做纯转发、不需要虚拟网卡，可以改成 true。
# 推荐设置：false
NO_TUN=false

# 监听地址列表，多个值用英文逗号分隔。
# 创建组网时至少应提供一个 TCP 或 UDP 监听入口。
# 推荐设置：同时保留 tcp://0.0.0.0:11010 和 udp://0.0.0.0:11010
LISTENER_URLS=tcp://0.0.0.0:11010,udp://0.0.0.0:11010

# 对外公布给其它节点连接的公网入口地址。
# 如果本机就是公网直连机器，通常写公网 IP + 端口。
# 推荐设置：填写真实公网 IP；如果没有公网直连能力，可以留空。
MAPPED_LISTENERS=tcp://122.123.124.125:11010,udp://122.123.124.125:11010

# 可选：当前节点还要主动连接的其它已知节点。
# 多个值用英文逗号分隔；没有则留空。
# 推荐设置：单入口节点场景留空。
PEER_URLS=

# 可选：要暴露给组网内其它节点访问的本地网段。
# 多个网段用英文逗号分隔，例如 192.168.1.0/24,10.0.0.0/24
# 推荐设置：默认留空，确实需要访问本地局域网时再填写。
PROXY_NETWORKS=

# easytier 的本地 RPC 管理地址。
# 用于 status、peer、route 等管理命令。
# 推荐设置：127.0.0.1:15888
RPC_PORTAL=127.0.0.1:15888

# 可选：手动指定 machine-id。
# 一般留空，脚本会自动使用系统标识。
# 推荐设置：留空
MACHINE_ID=

# 运行状态目录。
# 用于存放 machine-id、pid 等运行期数据。
# 推荐设置：保持默认
STATE_DIR=${ROOT_DIR}/.state/create

# 日志输出目录。
# 推荐设置：保持默认
LOG_DIR=${ROOT_DIR}/logs/create

# 控制台日志级别。
# 推荐设置：info；排障时可临时改成 debug（如果你确认版本支持）
CONSOLE_LOG_LEVEL=info

# 文件日志级别。
# 推荐设置：info
FILE_LOG_LEVEL=info

# 可选：允许的 TCP 端口白名单。
# 多个值用英文逗号分隔，例如 80,443,10000-10100
# 推荐设置：默认留空
TCP_WHITELIST=

# 可选：允许的 UDP 端口白名单。
# 推荐设置：默认留空
UDP_WHITELIST=

# 可选：透传给 easytier-core 的额外参数。
# 多个值用英文逗号分隔；带值参数写成 key=value。
# 例如：--disable-ipv6=true,--mtu=1360
# 推荐设置：默认留空，只有明确需要高级参数时再填写
EXTRA_ARGS=

